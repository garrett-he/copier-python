[project]
name = "{{ project_name }}"
version = "{{ project_version }}"
description = "{{ project_description }}"
requires-python = "{{ python_version }}"
authors = [
  { name = "{{ copyright_holder_name }}", email = "{{ copyright_holder_email }}" }
]
readme = "README.md"
license = { text = "{{ copyright_license }}" }
{% if project_keywords %}
keywords = ["{{ project_keywords.split(',') | join('", "') }}"]
{% endif %}
classifiers = [
  "Development Status :: 2 - Pre-Alpha",
  "Programming Language :: Python :: 3",
  {% for i in python_version | version_list(['3.12', '3.13', '3.14']) %}
  "Programming Language :: Python :: {{ i }}",
  {% endfor %}
]
dependencies = [
  {% if with_cli %}
  "typer>=0.25.1",
  {% endif %}
]

[project.urls]
Homepage = "https://github.com/{{ vcs_github_path }}"
Repository = "https://github.com/{{ vcs_github_path }}.git"
Issues = "https://github.com/{{ vcs_github_path }}/issues"
Changelog = "https://github.com/{{ vcs_github_path }}/blob/main/CHANGELOG.md"

{% if with_cli %}
[project.scripts]
{{ project_package }} = "{{ project_package }}.cli:app"
{% endif %}

[project.optional-dependencies]
dev = [
  "mypy>=2.1.0",
  "pre-commit>=4.6.0",
  "pytest>=9.0.3",
  "pytest-cov>=7.1.0",
  "ruff>=0.15.13",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_package }}"]

[tool.ruff]
line-length = 120
indent-width = 4

[tool.ruff.format]
quote-style = "single"
indent-style = "space"
line-ending = "lf"

[tool.ruff.lint]
select = ["E", "W", "F", "I", "N", "UP", "D", "B", "SIM", "C4", "TCH", "RUF"]

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.mypy]
strict = true
show_error_codes = true

[tool.pytest.ini_options]
addopts = "-ra --strict-markers --strict-config"

[tool.coverage.run]
source = ["{{ project_package }}"]

[tool.coverage.report]
fail_under = 80
show_missing = true
