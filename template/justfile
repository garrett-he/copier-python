default:
    just --list

install-dev:
    uv sync --extra dev

pre-commit: install-dev
    uv run pre-commit install

lint:
    uv run ruff check src tests
    uv run ruff format --check src tests

typecheck:
    uv run mypy src tests

format:
    uv run ruff format src tests

test:
    uv run pytest

build:
    uv build

publish:
    uv publish
